year, month, start_date, end_date = get_month_start_end(TARGET_DATE)

print("=" * 80)
print(f"Target date: {TARGET_DATE}")
print(f"Year-month file: {year}-{month:02d}")
print("=" * 80)

counties = gpd.read_file(COUNTY_SHP)
counties = counties.to_crs("EPSG:4326")

counties = counties[counties["STATEFP"].isin(STATEFP_TO_KEEP.keys())].copy()
counties["state_name"] = counties["STATEFP"].map(STATEFP_TO_KEEP)

print(f"Selected counties: {len(counties)}")
print(counties[["STATEFP", "state_name", "NAME", "GEOID"]].head())

file_url, filename = find_noaa_file(year, start_date, end_date)

raw_year_dir = RAW_DIR / str(year)
raw_year_dir.mkdir(exist_ok=True)

tar_path = raw_year_dir / filename
download_file(file_url, tar_path)

extract_month_dir = EXTRACT_DIR / f"{year}_{month:02d}"
nc_files = extract_tar(tar_path, extract_month_dir)

all_outputs = []

for nc_path in nc_files:
    try:
        county_df = aggregate_one_netcdf_to_counties(
            nc_path,
            counties,
            TARGET_DATE
        )

        if county_df is not None:
            all_outputs.append(county_df)

    except Exception as e:
        print(f"[ERROR] Failed for {nc_path.name}")
        print(e)

if not all_outputs:
    raise RuntimeError("No county-level outputs were created.")

final_df = all_outputs[0]

for df in all_outputs[1:]:
    final_df = final_df.merge(
        df,
        on=["GEOID", "STATEFP", "state_name", "NAME"],
        how="outer"
    )

final_df = final_df.rename(columns={
    "GEOID": "county_fips",
    "NAME": "county"
